# Supabase (lấy ở Project Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection — dùng "Session pooler" (port 5432), KHÔNG dùng direct (IPv6)
# Project Settings → Database → Connection string → Session pooler
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
